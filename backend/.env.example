# ============================================================
# 小黄鱼任务中心 - 环境变量配置模板
# ============================================================
# 
# 部署说明：
# 1. 复制此文件为 .env
# 2. 填写实际的配置值
#
# ============================================================

# ===================
# 服务器配置
# ===================
PORT=8080
NODE_ENV=development

# ===================
# 数据库配置 (Supabase PostgreSQL)
# ===================
# Transaction pooler - 应用连接（IPv4 兼容，推荐生产环境使用）
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres"

# Direct connection - 迁移和管理用（仅开发环境）
DIRECT_DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ===================
# Supabase 服务配置
# ===================
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-role-key"

# ===================
# JWT 配置
# ===================
# 生产环境请使用强密钥，至少32个字符
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# ===================
# Redis 配置（可选）
# ===================
# 留空则禁用缓存功能
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ===================
# 文件上传配置
# ===================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ===================
# 系统配置
# ===================
DEFAULT_TIME_LIMIT_MINUTES=10
MAX_CONCURRENT_PER_USER=5
CITY_LIMIT_PER_TASK=1
PROVINCE_LIMIT_PER_TASK=4

# ===================
# 积分配置
# ===================
POINTS_TO_YUAN=100
MIN_WITHDRAW_AMOUNT=10
