# ============================================================
# 小黄鱼任务中心 - 环境变量配置示例
# 注意：请复制此文件为 .env 并修改实际值
# ============================================================

# ============ 服务器配置 ============
PORT=3001
NODE_ENV=production

# ============ 数据库配置 ============
# PostgreSQL / CockroachDB 连接字符串
DATABASE_URL=postgresql://user:password@localhost:5432/xiaohuangyu?connection_limit=20&pool_timeout=30
DIRECT_DATABASE_URL=postgresql://user:password@localhost:5432/xiaohuangyu?connection_limit=5

# ============ Supabase 配置 ============
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# COZE 环境变量兼容（可选）
COZE_SUPABASE_URL=your-supabase-url
COZE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ============ JWT 配置 ============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============ Redis 配置 ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ============ PaddleOCR 配置 ============
PADDLE_OCR_URL=http://localhost:8088
PADDLE_OCR_TIMEOUT=120000
PADDLE_OCR_ENABLED=true
PADDLE_OCR_QUEUE_MODE=false

# ============ 文件上传配置 ============
UPLOAD_DIR=/data/images/uploads
MAX_FILE_SIZE=5242880

# ============ WebSocket 配置 ============
WS_HEARTBEAT_INTERVAL=30000
WS_HEARTBEAT_TIMEOUT=60000

# ============ 队列配置 ============
QUEUE_CONCURRENCY=5
QUEUE_MAX_ATTEMPTS=3

# ============ 日志配置 ============
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============ 监控配置 ============
MONITOR_ENABLED=true
MONITOR_INTERVAL=60000

# ============ 安全配置 ============
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
