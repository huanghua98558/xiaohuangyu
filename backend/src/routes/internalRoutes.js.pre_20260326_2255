/**
 * 内部 API 路由（供 Browser Service 调用）
 * 安全增强版 - 使用双重验证机制
 */
import express from 'express'
import logger from '../utils/logger.js'

const router = express.Router()

// 内部 API 密钥（从环境变量获取）
const INTERNAL_API_KEY = process.env.INTERNAL_API_KEY

// IP 白名单中间件 - 增强版
const internalOnly = (req, res, next) => {
  // 1. 检查 IP 地址（考虑反向代理）
  const forwardedFor = req.headers['x-forwarded-for']
  const realIp = req.headers['x-real-ip']
  const socketIp = req.socket?.remoteAddress
  const connectionIp = req.connection?.remoteAddress
  
  // 获取所有可能的 IP
  const possibleIPs = [
    req.ip,
    forwardedFor?.split(',')[0]?.trim(),
    realIp,
    socketIp,
    connectionIp
  ].filter(Boolean)
  
  // 检查是否全部为本地 IP
  const isLocalhost = possibleIPs.every(ip => {
    if (!ip) return false
    const normalized = ip.replace(/^::ffff:/, '')
    return normalized === '127.0.0.1' || normalized === '::1' || normalized === 'localhost'
  })
  
  // 2. 如果 IP 检查通过，直接放行
  if (isLocalhost) {
    return next()
  }
  
  // 3. 如果不是本地 IP，检查 API Key（允许带密钥的内部调用）
  if (INTERNAL_API_KEY) {
    const authHeader = req.headers['x-internal-api-key'] || req.headers['authorization']
    if (authHeader === INTERNAL_API_KEY || authHeader === `Bearer ${INTERNAL_API_KEY}`) {
      return next()
    }
  }
  
  // 4. 拒绝访问
  logger.warn("[Internal API] 拒绝非授权访问:", {
    ips: possibleIPs,
    hasApiKey: !!req.headers['x-internal-api-key'],
    path: req.path
  })
  return res.status(403).json({ code: 403, message: "Forbidden" })
}

router.use(internalOnly)

/**
 * 获取当前代理模式
 */
router.get("/ip/mode", async (req, res) => {
  try {
    const { getRedisClient } = await import("../utils/redis.js")
    const client = await getRedisClient()
    
    if (!client) {
      return res.json({ code: 200, data: { mode: "direct" } })
    }
    
    const mode = await client.get("proxy:mode") || "direct"
    const cooldownEnd = await client.get("proxy:mode:cooldown")
    
    res.json({
      code: 200,
      data: {
        mode,
        cooldownRemaining: cooldownEnd ? Math.max(0, parseInt(cooldownEnd) - Date.now()) : 0
      }
    })
  } catch (error) {
    logger.error('[Internal API] 获取 IP 模式失败:', error)
    res.status(500).json({ code: 500, message: error.message })
  }
})

