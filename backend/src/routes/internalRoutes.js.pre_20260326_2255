/**
 * 获取队列状态
 */
router.get("/queue/status", async (req, res) => {
  try {
    const { Queue } = await import("bullmq")
    const redisConnection = (await import("../config/queue.js")).default
    const db = (await import("../config/database.js")).default
    
    const queues = [
      { name: "link-verify-queue", displayName: "链接验证队列" },
      { name: "link-delay-queue", displayName: "连接延迟队列" }
    ]

    const [imageQueueStats, results] = await Promise.all([
      db.queryOne(
        `
        SELECT
          COUNT(*) FILTER (WHERE status = 'pending')::int AS waiting,
          COUNT(*) FILTER (WHERE status = 'processing')::int AS active,
          COUNT(*) FILTER (WHERE status = 'completed')::int AS completed,
          COUNT(*) FILTER (WHERE status = 'failed')::int AS failed
        FROM ai_review_queue
        `
      ),
      queues.map(async (q) => {
        try {
          const queue = new Queue(q.name, { connection: redisConnection })
          const [waiting, active, completed, failed] = await Promise.all([
            queue.getWaitingCount(),
            queue.getActiveCount(),
            queue.getCompletedCount(),
            queue.getFailedCount()
          ])
          return {
            name: q.displayName,
            queueName: q.name,
            waiting,
            active,
            completed,
            failed
          }
        } catch (e) {
          return {
            name: q.displayName,
            queueName: q.name,
            error: e.message,
            waiting: 0,
            active: 0,
            completed: 0,
            failed: 0
          }
        }
      })
    ])

    const allQueues = [
      {
        name: "图片审核队列",
        queueName: "ai_review_queue",
        waiting: Number(imageQueueStats?.waiting || 0),
        active: Number(imageQueueStats?.active || 0),
        completed: Number(imageQueueStats?.completed || 0),
        failed: Number(imageQueueStats?.failed || 0)
      },
      ...results
    ]
    const waiting = allQueues.reduce((sum, item) => sum + Number(item.waiting || 0), 0)
    const active = allQueues.reduce((sum, item) => sum + Number(item.active || 0), 0)
    const completed = allQueues.reduce((sum, item) => sum + Number(item.completed || 0), 0)
    const failed = allQueues.reduce((sum, item) => sum + Number(item.failed || 0), 0)
    
    res.json({
      code: 200,
      data: {
        waiting,
        active,
        completed,
        failed,
        queues: allQueues
      }
    })
  } catch (error) {
    logger.error('[Internal API] 获取队列状态失败:', error)
    res.status(500).json({ code: 500, message: error.message })
  }
})

export default router
