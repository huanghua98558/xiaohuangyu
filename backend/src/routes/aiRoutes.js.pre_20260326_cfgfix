// 处理审核报告 - 审核员/管理员
router.post('/reviewer/reports/:id/resolve', reviewerAuth, async (req, res) => {
  try {
    const reportId = parseInt(req.params.id)
    const { decision, note } = req.body
    
    if (!decision) {
      return res.status(400).json({ code: 400, message: '请提供审核决定', data: null })
    }
    
    // 获取报告
    const { data: report, error: reportError } = await supabase
      .from('review_reports')
      .select('claim_id')
      .eq('id', reportId)
      .single()
    
    if (reportError || !report) {
      return res.status(404).json({ code: 404, message: '报告不存在', data: null })
    }
    
    // 执行审核决定
    if (decision === 'approve') {
      await manualApprove(report.claim_id, req.userId, note || '')
    } else if (decision === 'reject') {
      await manualReject(report.claim_id, req.userId, note || '')
    }
    
    // 更新报告状态
    await supabase
      .from('review_reports')
      .update({
        status: 'resolved',
        human_decision: decision,
        human_note: note,
        reviewer_id: req.userId,
        resolved_at: new Date().toISOString()
      })
      .eq('id', reportId)
    
    res.json({ code: 0, message: '处理完成', data: { reportId, decision } })
  } catch (error) {
    logger.error('处理审核报告失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

