// 批量AI审核 - 审核员/管理员
router.post('/reviewer/batch-review', adminOrReviewerAuth, async (req, res) => {
  try {
    const { claims } = req.body
    const { enqueueReview } = await import('../services/ai/queueService.js')

    const claimIds = Array.isArray(claims)
      ? claims.map(item => Number(item?.claimId || item?.id || item)).filter(Number.isFinite)
      : []

    let queued = 0
    for (const claimId of claimIds) {
      await enqueueReview(claimId)
      queued++
    }

    res.json({ code: 0, message: '已加入审核队列', data: { queued } })
  } catch (error) {
    logger.error('批量审核失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 人工审核 - 审核员/管理员
router.post('/reviewer/manual', adminOrReviewerAuth, async (req, res) => {
