// 更新自定义模板 - 发布者/审核员/管理员
router.put('/templates/:id', publisherAuth, async (req, res) => {
  try {
    const templateId = parseInt(req.params.id)
    const { name, platform, action, reward, remain, timeLimitMinutes, description } = req.body
    
    // 检查模板是否存在且属于当前用户
    const { data: existing, error: checkError } = await supabase
      .from('ai_quick_templates')
      .select('id, user_id, is_default')
      .eq('id', templateId)
      .single()
    
    if (checkError || !existing) {
      return res.status(404).json({ code: 404, message: '模板不存在', data: null })
    }
    
    if (existing.is_default) {
      return res.status(400).json({ code: 400, message: '默认模板不能编辑', data: null })
    }
    
    if (existing.user_id !== req.userId) {
      return res.status(403).json({ code: 403, message: '无权编辑此模板', data: null })
    }
    
    const { data: template, error } = await supabase
      .from('ai_quick_templates')
      .update({
        name,
        platform,
        action: action || 'short_video_research',
        reward: reward || 30,
        remain: remain || 10,
        time_limit_minutes: timeLimitMinutes || 15,
        description: description || '',
        updated_at: new Date().toISOString()
      })
      .eq('id', templateId)
      .select()
      .single()
    
    if (error) throw error
    
    res.json({ 
      code: 200, 
      message: '更新成功', 
      data: {
        id: template.id,
        name: template.name,
        platform: template.platform,
        platformName: PLATFORM_NAMES[template.platform] || template.platform,
        action: template.action,
        reward: template.reward,
        remain: template.remain,
        timeLimitMinutes: template.time_limit_minutes,
        description: template.description,
        isDefault: false,
        canEdit: true
      }
    })
  } catch (error) {
    logger.error('更新模板失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 删除自定义模板 - 发布者/审核员/管理员
router.delete('/templates/:id', publisherAuth, async (req, res) => {
  try {
    const templateId = parseInt(req.params.id)
    
