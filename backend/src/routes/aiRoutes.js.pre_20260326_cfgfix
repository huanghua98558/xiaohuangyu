// 批量处理队列
router.post('/admin/process-queue', adminAuth, async (req, res) => {
  try {
    const { count = 100 } = req.body
    const { enqueueReview } = await import('../services/ai/queueService.js')
    const pendingClaims = await db.queryMany(
      `
      SELECT c.id
      FROM claims c
      LEFT JOIN ai_review_queue q
        ON q.claim_id = c.id
       AND q.status IN ('pending', 'processing')
      WHERE c.status IN ($1, $2)
        AND c.screenshots IS NOT NULL
        AND c.screenshots::text != '[]'
        AND q.id IS NULL
      ORDER BY c.submitted_at ASC NULLS LAST, c.id ASC
      LIMIT $3
      `,
      [
        CLAIM_STATUS.SUBMITTED,
        CLAIM_STATUS.IMAGE_REVIEWING,
        Number(count) || 100
      ]
    )

    let queued = 0
    for (const item of pendingClaims) {
      await enqueueReview(item.id)
      queued++
    }

    res.json({ code: 0, message: '已加入审核队列', data: { queued } })
  } catch (error) {
    logger.error('批量处理队列失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

