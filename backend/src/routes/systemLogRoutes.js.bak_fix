import { Router } from 'express'
import systemLogService from '../services/systemLogService.js'
import { authMiddleware, adminOnly } from '../middlewares/auth.js'
import { success, error } from '../utils/response.js'
import logger from '../utils/logger.js'

const router = Router()

// 所有接口都需要管理员权限
router.use(authMiddleware)
router.use(adminOnly)

/**
 * 获取统计概览
 * GET /api/admin-v2/logs/overview
 */
router.get('/overview', async (req, res, next) => {
  try {
    const stats = await systemLogService.getStatsOverview()
    success(res, stats)
  } catch (err) {
    next(err)
  }
})

/**
 * 获取操作日志
 * GET /api/admin-v2/logs/operation
 */
router.get('/operation', async (req, res, next) => {
  try {
    const { page, size, startDate, endDate, keyword, action, targetType, operatorRole } = req.query
    const result = await systemLogService.getOperationLogs({
      page: parseInt(page) || 1,
      size: parseInt(size) || 20,
      startDate,
      endDate,
      keyword,
      action,
      targetType,
      operatorRole
    })
    success(res, result)
  } catch (err) {
    next(err)
  }
})

/**
 * 获取登录日志
 * GET /api/admin-v2/logs/login
 */
router.get('/login', async (req, res, next) => {
  try {
    const { page, size, startDate, endDate, keyword, loginStatus, isAnomaly } = req.query
    const result = await systemLogService.getLoginLogs({
      page: parseInt(page) || 1,
      size: parseInt(size) || 20,
      startDate,
      endDate,
      keyword,
      loginStatus,
      isAnomaly
    })
    success(res, result)
  } catch (err) {
    next(err)
  }
})

/**
 * 获取审核日志
 * GET /api/admin-v2/logs/review
 */
router.get('/review', async (req, res, next) => {
  try {
    const { page, size, startDate, endDate, status, reviewerId } = req.query
    const result = await systemLogService.getReviewLogs({
      page: parseInt(page) || 1,
