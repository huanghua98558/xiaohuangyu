// 获取服务状态 - 审核员/管理员
router.get('/reviewer/services', reviewerAuth, async (req, res) => {
  try {
    const services = {
      ocr: { healthy: false, url: 'http://localhost:9001' },
      yolo: { healthy: false, url: 'http://localhost:9002' },
      browser: { healthy: false, url: 'http://localhost:5003' }
    }
    
    // 检查 OCR 服务
    try {
      const ocrRes = await fetch('http://localhost:9001/health', { 
        method: 'GET',
        signal: AbortSignal.timeout(3000)
      })
      if (ocrRes.ok) {
        const data = await ocrRes.json()
        services.ocr.healthy = data.status === 'ok'
      }
    } catch (e) {
      services.ocr.error = e.message
    }
    
    // 检查 YOLO 服务
    try {
      const yoloRes = await fetch('http://localhost:9002/health', {
        method: 'GET',
        signal: AbortSignal.timeout(3000)
      })
      if (yoloRes.ok) {
        const data = await yoloRes.json()
        services.yolo.healthy = data.status === 'ok'
      }
    } catch (e) {
      services.yolo.error = e.message
    }
    
    // 检查链接验证服务 (browser)
    try {
      const browserRes = await fetch('http://localhost:5003/api/health', {
        method: 'GET',
        signal: AbortSignal.timeout(3000)
      })
      if (browserRes.ok) {
        services.browser.healthy = true
      }
    } catch (e) {
      // 尝试备用路径
      try {
        const browserRes2 = await fetch('http://localhost:5003/health', {
          method: 'GET',
          signal: AbortSignal.timeout(3000)
        })
        services.browser.healthy = browserRes2.ok
      } catch (e2) {
        services.browser.error = e2.message
      }
    }
    
    res.json({ code: 200, message: '获取成功', data: services })
  } catch (error) {
    logger.error('获取服务状态失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 批量AI审核 - 审核员/管理员
router.post('/reviewer/batch-review', reviewerAuth, async (req, res) => {
  try {
    const { claims, config } = req.body
    const result = await batchProcessQueue(claims?.length || 10, req.headers)
    res.json({ code: 200, message: '批量审核完成', data: result })
  } catch (error) {
    logger.error('批量审核失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 人工审核 - 审核员/管理员
router.post('/reviewer/manual', reviewerAuth, async (req, res) => {
  try {
    const { claimId, action, note } = req.body
    
    if (!claimId || !action) {
      return res.status(400).json({ code: 400, message: '参数不完整', data: null })
    }
    
    let result
    if (action === 'approve') {
      result = await manualApprove(claimId, req.userId, note || '')
    } else {
      result = await manualReject(claimId, req.userId, note || '')
    }
    
    res.json({ code: 200, message: result.message, data: result })
  } catch (error) {
    logger.error('人工审核失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 与审核助手对话（流式）- 审核员/管理员
router.post('/reviewer/chat', reviewerAuth, async (req, res) => {
  try {
    const { message, conversationId } = req.body
    
    if (!message) {
      return res.status(400).json({ code: 400, message: '消息不能为空', data: null })
    }
    
    const headers = req.headers
    const generator = chatWithReviewer(req.userId, message, conversationId, headers)
    
    createSSEStream(generator, res, req)
  } catch (error) {
    logger.error('审核助手对话失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

