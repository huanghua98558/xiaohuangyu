// 更新审核规则 - 管理员
router.post('/admin/review-rules/:id', adminAuth, async (req, res) => {
  try {
    const ruleId = parseInt(req.params.id)
    const updates = req.body
    
    updates.updated_at = new Date().toISOString()
    
    const { error } = await supabase
      .from('review_rules')
      .update(updates)
      .eq('id', ruleId)
    
    if (error) throw error
    
    res.json({ code: 200, message: '更新成功', data: null })
  } catch (error) {
    logger.error('更新审核规则失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// ========== 图片审核设置 API ==========

/**
 * 获取图片审核设置
 */
router.get('/admin/review-settings', adminAuth, async (req, res) => {
  try {
    const { data, error } = await supabase
      .from('ai_configs')
      .select('key, value')
      .eq('key', 'image_review_settings')
      .single()
    
    if (error && error.code !== 'PGRST116') {
      throw error
    }
    
    const settings = data?.value ? JSON.parse(data.value) : {
      checks: {
        follow: true,
        like: true,
        favorite: true,
        comment: true,
        authorName: true,
        commentNickname: true
      }
    }
    
    res.json({ code: 200, message: '获取成功', data: settings })
  } catch (error) {
    logger.error('获取图片审核设置失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

/**
 * 保存图片审核设置
 */
router.post('/admin/review-settings', adminAuth, async (req, res) => {
  try {
    const { checks } = req.body
    
    const settings = { checks }
    const now = new Date().toISOString()
    
    const { error } = await supabase
      .from('ai_configs')
      .upsert({
        key: 'image_review_settings',
        value: JSON.stringify(settings),
        category: 'image_review',
        is_enabled: true,
        updated_at: now
      }, { onConflict: 'key' })
    
    if (error) throw error
    
    res.json({ code: 200, message: '保存成功', data: null })
  } catch (error) {
    logger.error('保存图片审核设置失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// ========== 链接审查配置 API ==========

/**
 * 获取链接审查配置
 */
router.get('/admin/link-review-settings', adminAuth, async (req, res) => {
  try {
    // 从 Redis 获取配置
    const { getRedisClient } = await import('../utils/redis.js')
    const client = await getRedisClient()
    
    if (!client) {
      return res.json({
        code: 200,
        message: '获取成功',
        data: {
          basic: {
            batchSize: parseInt(process.env.LINK_BATCH_SIZE) || 10,
            waitTime: parseInt(process.env.LINK_WAIT_TIME) || 5,
            timeout: parseInt(process.env.LINK_TIMEOUT) || 30,
            maxRetries: parseInt(process.env.LINK_MAX_RETRIES) || 3,
            concurrentLimit: parseInt(process.env.LINK_CONCURRENT_LIMIT) || 5
          },
          proxy: {
            enabled: process.env.PROXY_ENABLED !== 'false',
            mode: await client?.get('proxy:mode') || 'auto',
            queueThreshold: parseInt(process.env.PROXY_QUEUE_THRESHOLD) || 20,
            directFailLimit: parseInt(process.env.PROXY_DIRECT_FAIL_LIMIT) || 3,
            directCooldown: parseInt(process.env.PROXY_DIRECT_COOLDOWN) || 30,
            captchaCooldown: parseInt(process.env.PROXY_CAPTCHA_COOLDOWN) || 60,
            ipUsageLimit: parseInt(process.env.PROXY_USAGE_LIMIT) || 200,
            ipTtlMin: parseInt(process.env.PROXY_TTL_MIN) || 300,
            ipTtlMax: parseInt(process.env.PROXY_TTL_MAX) || 900
          },
          riskDetection: {
            enabled: true,
            keywords: ['验证码', '访问频繁', '安全验证', '滑动验证', '图形验证'],
            autoSwitchOnCaptcha: true
          },
          browser: {
            browserCount: parseInt(process.env.BROWSER_COUNT) || 3,
            contextsPerBrowser: parseInt(process.env.CONTEXTS_PER_BROWSER) || 10,
            headless: true,
            disableImages: true
          }
        }
      })
    }
    
    // 从数据库获取存储的配置
    const { data } = await supabase
      .from('system_config')
      .select('value')
      .eq('key', 'link_review_settings')
      .single()
    
    if (data?.value) {
      return res.json({
        code: 200,
        message: '获取成功',
        data: data.value
      })
    }
    
    // 返回默认配置
    res.json({
      code: 200,
      message: '获取成功',
      data: {
        basic: {
          batchSize: 10,
          waitTime: 5,
          timeout: 30,
          maxRetries: 3,
          concurrentLimit: 5
        },
        proxy: {
          enabled: true,
          mode: await client.get('proxy:mode') || 'auto',
          queueThreshold: 20,
          directFailLimit: 3,
          directCooldown: 30,
          captchaCooldown: 60,
          ipUsageLimit: 200,
          ipTtlMin: 300,
          ipTtlMax: 900
        },
        riskDetection: {
          enabled: true,
          keywords: ['验证码', '访问频繁', '安全验证', '滑动验证'],
          autoSwitchOnCaptcha: true
        },
        browser: {
          browserCount: 3,
          contextsPerBrowser: 10,
          headless: true,
          disableImages: true
        }
      }
    })
  } catch (error) {
    logger.error('获取链接审查配置失败:', error)
    res.status(500).json({ code: 500, message: '获取配置失败' })
  }
})

/**
 * 更新链接审查配置
 */
router.post('/admin/link-review-settings', adminAuth, async (req, res) => {
  try {
    const config = req.body
    
    // 保存到数据库
    const { error } = await supabase
      .from('system_config')
      .upsert({
        key: 'link_review_settings',
        value: config,
        updated_at: new Date().toISOString()
      })
    
    if (error && error.code !== '42P01') {
      throw error
    }
    
    // 更新 Redis 中的模式
    if (config.proxy?.mode) {
      const { getRedisClient } = await import('../utils/redis.js')
      const client = await getRedisClient()
      if (client) {
        await client.set('proxy:mode', config.proxy.mode)
      }
    }
    
    res.json({
      code: 200,
      message: '配置已更新'
    })
  } catch (error) {
    logger.error('更新链接审查配置失败:', error)
    res.status(500).json({ code: 500, message: '更新配置失败' })
  }
})

/**
 * 获取代理统计信息
 */
router.get('/admin/proxy-stats', adminAuth, async (req, res) => {
  try {
    const { getRedisClient } = await import('../utils/redis.js')
    const client = await getRedisClient()
    
    if (!client) {
      return res.json({
        code: 200,
        message: '获取成功',
        data: {
          mode: 'direct',
          poolSize: 0,
          directRequests: 0,
          proxyRequests: 0,
          captchaHits: 0,
          modeSwitches: 0,
          directFailCount: 0,
          cooldownRemaining: 0
        }
      })
    }
    
    const mode = await client.get('proxy:mode') || 'direct'
    const poolSize = await client.lLen('proxy:pool:available')
    const stats = await client.hGetAll('proxy:stats') || {}
    const directFailCount = parseInt(await client.get('proxy:direct:failCount') || '0')
    const cooldownEnd = await client.get('proxy:mode:cooldown')
    
    res.json({
      code: 200,
      message: '获取成功',
      data: {
        mode,
        poolSize,
        directRequests: parseInt(stats.directRequests || '0'),
        proxyRequests: parseInt(stats.proxyRequests || '0'),
        captchaHits: parseInt(stats.captchaHits || '0'),
        modeSwitches: parseInt(stats.modeSwitches || '0'),
        directFailCount,
        cooldownRemaining: cooldownEnd ? Math.max(0, parseInt(cooldownEnd) - Date.now()) : 0
      }
    })
  } catch (error) {
    logger.error('获取代理统计失败:', error)
    res.status(500).json({ code: 500, message: '获取统计失败' })
  }
})

/**
 * 设置代理模式
 */
router.post('/admin/proxy-mode', adminAuth, async (req, res) => {
  try {
    const { mode } = req.body
    
    if (!['direct', 'proxy', 'auto'].includes(mode)) {
      return res.status(400).json({ code: 400, message: '无效的模式' })
    }
    
    const { getRedisClient } = await import('../utils/redis.js')
    const client = await getRedisClient()
    
    if (!client) {
      return res.status(500).json({ code: 500, message: 'Redis 未连接' })
    }
    
    await client.set('proxy:mode', mode)
    await client.del('proxy:mode:cooldown')  // 清除冷却
    
    logger.info(`[代理模式] 管理员手动切换为: ${mode}`)
    
    res.json({
      code: 200,
      message: `已切换到${mode === 'direct' ? '直连' : mode === 'proxy' ? '代理' : '智能'}模式`,
      data: { mode }
    })
  } catch (error) {
    logger.error('设置代理模式失败:', error)
    res.status(500).json({ code: 500, message: '设置失败' })
  }
})

/**
 * 预热代理 IP 池
 */
router.post('/admin/proxy-warmup', adminAuth, async (req, res) => {
  try {
    const { count = 5 } = req.body
    
    const ipDispenser = (await import('../services/ai/ipDispenserService.js')).default
    await ipDispenser.warmup(count)
    
    res.json({
      code: 200,
      message: `已预热 ${count} 个 IP`
    })
  } catch (error) {
    logger.error('预热代理池失败:', error)
    res.status(500).json({ code: 500, message: '预热失败' })
  }
})


/**
 * ========== 内部 API（供 Browser Service 调用）==========
 */

/**
 * 获取当前代理模式
 * 内部接口，不需要认证
 */
router.get("/internal/ip/mode", async (req, res) => {
  try {
    const { getRedisClient } = await import("../utils/redis.js")
    const client = await getRedisClient()
    
    if (!client) {
      return res.json({ code: 200, data: { mode: "direct" } })
    }
    
    const mode = await client.get("proxy:mode") || "direct"
    const cooldownEnd = await client.get("proxy:mode:cooldown")
    
    res.json({
      code: 200,
      data: {
        mode,
        cooldownRemaining: cooldownEnd ? Math.max(0, parseInt(cooldownEnd) - Date.now()) : 0
      }
    })
  } catch (error) {
    res.status(500).json({ code: 500, message: error.message })
  }
})

/**
 * 获取一个代理 IP
 * 内部接口，不需要认证
 */
router.post("/internal/ip/acquire", async (req, res) => {
  try {
    const ipDispenser = (await import("../services/ai/ipDispenserService.js")).default
    const ipInfo = await ipDispenser.acquireIP()
    
    if (!ipInfo) {
      return res.json({ code: 503, message: "暂无可用 IP" })
    }
    
    res.json({
      code: 200,
      data: {
        ip: ipInfo.ip,
        port: ipInfo.port,
        proxyUrl: ipInfo.proxyUrl,
        expireTime: ipInfo.expireTime
      }
    })
  } catch (error) {
    res.status(500).json({ code: 500, message: error.message })
  }
})

/**
 * 归还代理 IP
 * 内部接口，不需要认证
 */
router.post("/internal/ip/return", async (req, res) => {
  try {
    const { ipInfo } = req.body
    
    if (!ipInfo) {
      return res.status(400).json({ code: 400, message: "缺少 ipInfo" })
    }
    
    const ipDispenser = (await import("../services/ai/ipDispenserService.js")).default
    await ipDispenser.returnToPool(ipInfo)
    
    res.json({ code: 200, message: "已归还" })
  } catch (error) {
    res.status(500).json({ code: 500, message: error.message })
  }
})

