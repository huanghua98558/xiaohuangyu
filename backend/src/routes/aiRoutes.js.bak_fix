// 更新AI配置
router.post('/admin/configs', adminAuth, async (req, res) => {
  try {
    const { key, value } = req.body
    await setConfig(key, value)
    res.json({ code: 200, message: '更新成功', data: null })
  } catch (error) {
    logger.error('更新配置失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 批量更新配置
router.post('/admin/configs/batch', adminAuth, async (req, res) => {
  try {
    const { updates, configs } = req.body
    const configList = updates || configs
    
    for (const { key, value } of configList) {
      await setConfig(key, value)
    }
    
    res.json({ code: 200, message: '批量更新成功', data: null })
  } catch (error) {
    logger.error('批量更新配置失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// ============ 模型配置接口 ============

// 获取模型配置（发布助手/审核助手）
router.get('/config/:type', adminAuth, async (req, res) => {
  try {
    const { type } = req.params // 'publisher' 或 'reviewer'
    
    if (!['publisher', 'reviewer'].includes(type)) {
      return res.status(400).json({ code: 400, message: '无效的配置类型', data: null })
    }
    
    const prefix = `${type}_`
    const provider = await getConfig(`${prefix}api_provider`, '')
    const providerName = await getConfig(`${prefix}api_provider_name`, '')
    const apiBaseUrl = await getConfig(`${prefix}api_base_url`, '')
    const apiKey = await getConfig(`${prefix}api_key`, '')
    const model = await getConfig(`${prefix}model`, '')
    
    res.json({
      code: 200,
      message: '获取成功',
      data: {
        config: {
          provider,
          providerName,
          apiBaseUrl,
          apiKey: apiKey ? '******' : '', // 不返回完整key
          hasApiKey: !!apiKey,
          model
        }
      }
    })
  } catch (error) {
    logger.error('获取模型配置失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 保存模型配置
router.post('/config/:type', adminAuth, async (req, res) => {
  try {
    const { type } = req.params // 'publisher' 或 'reviewer'
    const { provider, providerName, apiBaseUrl, apiKey, model } = req.body
    
    if (!['publisher', 'reviewer'].includes(type)) {
      return res.status(400).json({ code: 400, message: '无效的配置类型', data: null })
    }
    
    const prefix = `${type}_`
    
    // 保存各配置项
    if (provider) await setConfig(`${prefix}api_provider`, provider)
    if (providerName) await setConfig(`${prefix}api_provider_name`, providerName)
    if (apiBaseUrl) await setConfig(`${prefix}api_base_url`, apiBaseUrl)
    if (apiKey && apiKey !== '******') await setConfig(`${prefix}api_key`, apiKey) // 只有传入新key才更新
    if (model) await setConfig(`${prefix}model`, model)
    
    logger.info(`管理员 ${req.userId} 更新了${type === 'publisher' ? '发布助手' : '审核助手'}模型配置`)
    
    res.json({ code: 200, message: '保存成功', data: null })
  } catch (error) {
    logger.error('保存模型配置失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 测试API连接
router.post('/test-connection', adminAuth, async (req, res) => {
  try {
    const { apiBaseUrl, apiKey, model } = req.body
    
    if (!apiBaseUrl || !apiKey || !model) {
      return res.status(400).json({ code: 400, message: '参数不完整', data: null })
    }
    
    // 构造测试请求
    const testUrl = apiBaseUrl.endsWith('/') 
      ? `${apiBaseUrl}chat/completions` 
      : `${apiBaseUrl}/chat/completions`
    
    const response = await fetch(testUrl, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiKey}`
      },
      body: JSON.stringify({
        model,
        messages: [{ role: 'user', content: 'Hello' }],
        max_tokens: 10
      })
    })
    
    if (response.ok) {
      res.json({ code: 200, message: '连接成功', data: { success: true } })
    } else {
      const errorText = await response.text()
      let errorMessage = '连接失败'
      try {
        const errorJson = JSON.parse(errorText)
        errorMessage = errorJson.error?.message || errorJson.message || errorMessage
      } catch {
        errorMessage = errorText || errorMessage
      }
      res.json({ code: 200, message: '连接失败', data: { success: false, error: errorMessage } })
    }
  } catch (error) {
    logger.error('测试连接失败:', error)
    res.json({ code: 200, message: '连接失败', data: { success: false, error: error.message } })
  }
})

