// 获取审核报告列表（待人工审核）- 审核员/管理员
router.get('/reviewer/reports', reviewerAuth, async (req, res) => {
  try {
    const { status = 'pending', page = 1, pageSize = 20 } = req.query
    
    // 直接从claims查询待人工审核的数据（ai_review_status = 'manual'）
    const { data: claims, error } = await supabase
      .from('claims')
      .select('id, user_id, task_id, screenshots, status, image_review_status, link_review_status, ai_review_status, ai_confidence, ai_reason, claimed_at, tasks(id, title, platform, action), users(id, username)')
      .eq('ai_review_status', 'manual')
      .order('claimed_at', { ascending: false })
      .range((page - 1) * pageSize, page * pageSize - 1)
    
    if (error) throw error
    
    // 构造报告格式返回
    const reports = (claims || []).map(claim => ({
      id: claim.id,
      claim_id: claim.id,
      report_type: 'manual_review',
      priority: 0,
      status: 'pending',
      created_at: claim.claimed_at,
      ai_analysis: {
        screenshot: {
          dimension: 'screenshot',
          result: claim.image_review_status === 'passed' ? 'approved' : 
                  claim.image_review_status === 'failed' ? 'rejected' : 'manual',
          confidence: claim.ai_confidence || 0.5,
          details: { analysisText: claim.ai_reason || '待人工审核' }
        }
      },
      difficulty_reasons: [{
        dimension: 'screenshot',
        confidence: claim.ai_confidence || 0.5,
        issues: claim.ai_reason || '需要人工确认'
      }],
      claims: claim
    }))
    
    res.json({ code: 200, message: '获取成功', data: { list: reports, page, pageSize } })
  } catch (error) {
    logger.error('获取审核报告失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 处理审核报告 - 审核员/管理员
router.post('/reviewer/reports/:id/resolve', reviewerAuth, async (req, res) => {
  try {
    const reportId = parseInt(req.params.id)
    const { decision, note } = req.body
    
    if (!decision) {
      return res.status(400).json({ code: 400, message: '请提供审核决定', data: null })
    }
    
    // 获取报告
    const { data: report, error: reportError } = await supabase
      .from('review_reports')
      .select('claim_id')
      .eq('id', reportId)
      .single()
    
    if (reportError || !report) {
      return res.status(404).json({ code: 404, message: '报告不存在', data: null })
    }
    
    // 执行审核决定
    if (decision === 'approve') {
      await manualApprove(report.claim_id, req.userId, note || '')
    } else if (decision === 'reject') {
      await manualReject(report.claim_id, req.userId, note || '')
    }
    
    // 更新报告状态
    await supabase
      .from('review_reports')
      .update({
        status: 'resolved',
        human_decision: decision,
        human_note: note,
        reviewer_id: req.userId,
        resolved_at: new Date().toISOString()
      })
      .eq('id', reportId)
    
    res.json({ code: 200, message: '处理完成', data: { reportId, decision } })
  } catch (error) {
    logger.error('处理审核报告失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 获取可疑用户列表 - 审核员/管理员
router.get('/reviewer/suspicious-users', reviewerAuth, async (req, res) => {
  try {
    const { status = 'monitoring', page = 1, pageSize = 20 } = req.query
    
    const { data: users, error } = await supabase
      .from('suspicious_users')
      .select(`
        id, user_id, suspicion_type, suspicion_score, evidence, status, created_at,
        users (id, username, level, total_points)
      `)
      .neq('status', 'cleared')
      .order('suspicion_score', { ascending: false })
      .range((page - 1) * pageSize, page * pageSize - 1)
    
    if (error) throw error
    
    res.json({ code: 200, message: '获取成功', data: { list: users || [], page, pageSize } })
  } catch (error) {
    logger.error('获取可疑用户失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

