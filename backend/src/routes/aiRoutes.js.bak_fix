// ============ 公开接口（无需认证）============

// 浏览器服务状态检查 - 公开端点
router.get('/browser-status', async (req, res) => {
  try {
    // 动态导入以避免启动时加载
    const { healthCheck: browserHealthCheck } = await import('../services/ai/browserService.js')
    const result = await browserHealthCheck()
    res.json({ code: 200, message: '检查完成', data: result })
  } catch (error) {
    res.json({ 
      code: 200, 
      message: '检查完成', 
      data: {
        status: 'unavailable',
        error: error.message,
        hint: '浏览器自动化功能不可用，但不影响核心业务运行'
      }
    })
  }
})

// ============ 中间件 ============

// 全局认证中间件 - 所有AI接口都需要登录
