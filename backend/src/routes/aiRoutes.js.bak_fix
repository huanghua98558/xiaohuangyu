// ============ 发布助手接口 ============

// 与发布助手对话（流式）- 发布者/审核员/管理员
router.post('/publisher/chat', publisherAuth, async (req, res) => {
  try {
    const { message, conversationId } = req.body
    
    if (!message) {
      return res.status(400).json({ code: 400, message: '消息不能为空', data: null })
    }
    
    // 获取用户信息
    const { data: user } = await supabase
      .from('users')
      .select('id, username, role')
      .eq('id', req.userId)
      .single()
    
    const headers = req.headers
    const generator = chatWithPublisher(req.userId, message, conversationId, headers, user)
    
    createSSEStream(generator, res, req)
  } catch (error) {
    logger.error('发布助手对话失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 解析链接 - 发布者/审核员/管理员
router.post('/publisher/parse-link', publisherAuth, async (req, res) => {
  try {
    const { url } = req.body
    
    if (!url) {
      return res.status(400).json({ code: 400, message: '链接不能为空', data: null })
    }
    
    const result = await parseTaskUrl(url, req.headers)
    res.json({ code: 200, message: '解析成功', data: result })
  } catch (error) {
    logger.error('解析链接失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 检测链接格式
router.post('/publisher/detect-link', publisherAuth, async (req, res) => {
  try {
    const { text } = req.body
    
    if (!text) {
      return res.status(400).json({ code: 400, message: '文本不能为空', data: null })
    }
    
    const result = detectLink(text)
    res.json({ code: 200, message: '检测完成', data: result })
  } catch (error) {
    logger.error('检测链接失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// ============ 快捷模板接口 ============

// 平台名称映射
const PLATFORM_NAMES = {
  douyin: '抖音',
  xiaohongshu: '小红书',
  kuaishou: '快手',
  weibo: '微博',
  bilibili: 'B站'
}

// 获取快捷模板列表 - 发布者/审核员/管理员
router.get('/templates', publisherAuth, async (req, res) => {
  try {
    // 获取默认模板 + 用户自定义模板
    const { data: templates, error } = await supabase
      .from('ai_quick_templates')
      .select('*')
      .in('user_id', ['0', req.userId])
      .order('is_default', { ascending: false })
      .order('sort_order', { ascending: true })
      .order('created_at', { ascending: false })
    
    if (error) throw error
    
    // 格式化返回数据
    const formattedTemplates = (templates || []).map(t => ({
      id: t.id,
      name: t.name,
      platform: t.platform,
      platformName: PLATFORM_NAMES[t.platform] || t.platform,
      action: t.action,
      reward: t.reward,
      remain: t.remain,
      timeLimitMinutes: t.time_limit_minutes,
      description: t.description,
      isDefault: t.is_default,
      canEdit: !t.is_default && t.user_id === req.userId
    }))
    
    res.json({ code: 200, message: '获取成功', data: formattedTemplates })
  } catch (error) {
    logger.error('获取模板列表失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 创建自定义模板 - 发布者/审核员/管理员
router.post('/templates', publisherAuth, async (req, res) => {
  try {
    const { name, platform, action, reward, remain, timeLimitMinutes, description } = req.body
    
    if (!name || !platform) {
      return res.status(400).json({ code: 400, message: '模板名称和平台不能为空', data: null })
    }
    
    const { data: template, error } = await supabase
      .from('ai_quick_templates')
      .insert({
        user_id: req.userId,
        name,
        platform,
        action: action || 'short_video_research',
        reward: reward || 30,
        remain: remain || 10,
        time_limit_minutes: timeLimitMinutes || 15,
        description: description || '',
        is_default: false
      })
      .select()
      .single()
    
    if (error) throw error
    
    res.json({ 
      code: 200, 
      message: '创建成功', 
      data: {
        id: template.id,
        name: template.name,
        platform: template.platform,
        platformName: PLATFORM_NAMES[template.platform] || template.platform,
        action: template.action,
        reward: template.reward,
        remain: template.remain,
        timeLimitMinutes: template.time_limit_minutes,
        description: template.description,
        isDefault: false,
        canEdit: true
      }
    })
  } catch (error) {
    logger.error('创建模板失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 更新自定义模板 - 发布者/审核员/管理员
router.put('/templates/:id', publisherAuth, async (req, res) => {
  try {
    const templateId = parseInt(req.params.id)
    const { name, platform, action, reward, remain, timeLimitMinutes, description } = req.body
    
    // 检查模板是否存在且属于当前用户
    const { data: existing, error: checkError } = await supabase
      .from('ai_quick_templates')
      .select('id, user_id, is_default')
      .eq('id', templateId)
      .single()
    
    if (checkError || !existing) {
      return res.status(404).json({ code: 404, message: '模板不存在', data: null })
    }
    
    if (existing.is_default) {
      return res.status(400).json({ code: 400, message: '默认模板不能编辑', data: null })
    }
    
    if (existing.user_id !== req.userId) {
      return res.status(403).json({ code: 403, message: '无权编辑此模板', data: null })
    }
    
    const { data: template, error } = await supabase
      .from('ai_quick_templates')
      .update({
        name,
        platform,
        action: action || 'short_video_research',
        reward: reward || 30,
        remain: remain || 10,
        time_limit_minutes: timeLimitMinutes || 15,
        description: description || '',
        updated_at: new Date().toISOString()
      })
      .eq('id', templateId)
      .select()
      .single()
    
    if (error) throw error
    
    res.json({ 
      code: 200, 
      message: '更新成功', 
      data: {
        id: template.id,
        name: template.name,
        platform: template.platform,
        platformName: PLATFORM_NAMES[template.platform] || template.platform,
        action: template.action,
        reward: template.reward,
        remain: template.remain,
        timeLimitMinutes: template.time_limit_minutes,
        description: template.description,
        isDefault: false,
        canEdit: true
      }
    })
  } catch (error) {
    logger.error('更新模板失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 删除自定义模板 - 发布者/审核员/管理员
router.delete('/templates/:id', publisherAuth, async (req, res) => {
  try {
    const templateId = parseInt(req.params.id)
    
    // 检查模板是否存在且属于当前用户
    const { data: existing, error: checkError } = await supabase
      .from('ai_quick_templates')
      .select('id, user_id, is_default')
      .eq('id', templateId)
      .single()
    
    if (checkError || !existing) {
      return res.status(404).json({ code: 404, message: '模板不存在', data: null })
    }
    
    if (existing.is_default) {
      return res.status(400).json({ code: 400, message: '默认模板不能删除', data: null })
    }
    
    if (existing.user_id !== req.userId) {
      return res.status(403).json({ code: 403, message: '无权删除此模板', data: null })
    }
    
    const { error } = await supabase
      .from('ai_quick_templates')
      .delete()
      .eq('id', templateId)
    
    if (error) throw error
    
    res.json({ code: 200, message: '删除成功', data: null })
  } catch (error) {
    logger.error('删除模板失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

