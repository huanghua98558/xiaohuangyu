// 权限检查中间件
const publisherAuth = requireRoles('admin', 'client', 'reviewer')
const reviewerAuth = requireRoles('admin', 'reviewer')
const adminAuth = requireRoles('admin')

// ============ SSE 辅助函数 ============
function createSSEStream(generator, res, req) {
  const stream = new Readable({ read() {} })
  
  res.setHeader('Content-Type', 'text/event-stream')
  res.setHeader('Cache-Control', 'no-cache')
  res.setHeader('Connection', 'keep-alive')
  res.setHeader('X-Accel-Buffering', 'no')
  
  ;(async () => {
    try {
      for await (const chunk of generator) {
        const data = JSON.stringify({ content: chunk })
        stream.push(`data: ${data}\n\n`)
      }
      stream.push('data: [DONE]\n\n')
      stream.push(null)
    } catch (error) {
      logger.error('SSE流错误:', error)
      const errorData = JSON.stringify({ error: error.message })
      stream.push(`data: ${errorData}\n\n`)
      stream.push(null)
    }
  })()
  
  stream.pipe(res)
  
  req.on('close', () => {
    stream.destroy()
  })
}

// ============ 会话管理接口 ============

// 创建会话
router.post('/conversations', async (req, res) => {
  try {
    const { type, title, context } = req.body
    const conversation = await createConversation(req.userId, type, title, context)
    res.json({ code: 200, message: '创建成功', data: conversation })
  } catch (error) {
    logger.error('创建会话失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 获取会话列表
router.get('/conversations', async (req, res) => {
  try {
    const { type, page = 1, pageSize = 20 } = req.query
    const result = await getConversations(req.userId, type, { page, pageSize })
