// ============ 新增：多维度审核接口 ============

import {
  comprehensiveReview,
  batchComprehensiveReview
} from '../services/ai/reviewEngine.js'
import {
  parseCommand,
  executeCommand,
  formatReviewList
} from '../services/ai/reviewCommandService.js'
import {
  verifyComment,
  healthCheck as browserHealthCheck
} from '../services/ai/browserService.js'

// 多维度综合审核 - 审核员/管理员
router.post('/reviewer/comprehensive/:claimId', reviewerAuth, async (req, res) => {
  try {
    const claimId = parseInt(req.params.claimId)
    const { commentText } = req.body
    
    const result = await comprehensiveReview(claimId, {
      commentText,
      headers: req.headers
    })
    
    res.json({ code: 200, message: '审核完成', data: result })
  } catch (error) {
    logger.error('综合审核失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 批量综合审核 - 审核员/管理员
router.post('/reviewer/batch-comprehensive', reviewerAuth, async (req, res) => {
  try {
    const { claimIds } = req.body
    
    if (!claimIds || !Array.isArray(claimIds)) {
      return res.status(400).json({ code: 400, message: '请提供审核项ID数组', data: null })
    }
    
    const result = await batchComprehensiveReview(claimIds, { headers: req.headers })
    res.json({ code: 200, message: '批量审核完成', data: result })
  } catch (error) {
    logger.error('批量综合审核失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 审核指令解析与执行 - 审核员/管理员
router.post('/reviewer/command', reviewerAuth, async (req, res) => {
  try {
    const { message } = req.body
    
    if (!message) {
      return res.status(400).json({ code: 400, message: '指令不能为空', data: null })
    }
    
    // 解析指令
    const parsed = await parseCommand(message, req.headers)
    
    // 执行指令
    const result = await executeCommand(parsed, req.userId, req.headers)
    
    // 格式化输出
    if (result.type === 'query' && result.data?.list) {
      result.formattedList = formatReviewList(result.data.list)
    }
    
    res.json({ code: 200, message: result.message || '执行完成', data: result })
  } catch (error) {
    logger.error('执行审核指令失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

// 链接验证 - 审核员/管理员
router.post('/reviewer/verify-link', reviewerAuth, async (req, res) => {
  try {
    const { videoUrl, comment, userName } = req.body
    
    if (!videoUrl) {
      return res.status(400).json({ code: 400, message: '视频链接不能为空', data: null })
    }
    
    const result = await verifyComment(videoUrl, comment || '', userName || '')
    res.json({ code: 200, message: '验证完成', data: result })
  } catch (error) {
    logger.error('链接验证失败:', error)
    res.status(500).json({ code: 500, message: error.message, data: null })
  }
})

