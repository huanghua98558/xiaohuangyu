/**
 * 位置服务工具 - 优化版
 * 
 * GPS 逆地理编码：优先使用离线数据（无需 API 调用）
 * IP 定位：多源备用 + 本地 IP 库
 * 
 * V2.0 优化：
 * 1. 离线 GPS 逆地理编码（零依赖）
 * 2. IP 定位多源备用
 * 3. 移除高德 API 依赖
 */

import axios from 'axios'
import logger from './logger.js'
import https from 'https'
import { reverseGeocode as offlineReverseGeocode } from './offlineGeocoder.js'

// 创建 HTTPS Agent
const httpsAgent = new https.Agent({
  rejectUnauthorized: false
})

const axiosInstance = axios.create({
  httpsAgent: httpsAgent,
  timeout: 5000
})

// ============== GPS 逆地理编码 ==============

/**
 * GPS 逆地理编码：经纬度转省市
 * 
 * 优先级：
 * 1. 离线数据库（本地查询，毫秒级）
 * 2. 高德 API（备用，可选）
 * 
 * @param {number} lng 经度
 * @param {number} lat 纬度
 * @returns {Promise<{province: string, city: string, district: string}>}
 */
export async function reverseGeocode(lng, lat) {
  try {
    console.log('[地理编码] 请求:', lng, lat)

    // 第一优先：离线查询（毫秒级，无网络依赖）
    const offlineResult = offlineReverseGeocode(lng, lat)
    
    if (offlineResult && offlineResult.confidence > 0.5) {
      console.log('[地理编码] 离线查询成功:', offlineResult.province, offlineResult.city)
      return {
        province: offlineResult.province,
        city: offlineResult.city,
        district: offlineResult.district || '',
        formattedAddress: `${offlineResult.province}${offlineResult.city}`,
        source: 'offline'
      }
    }

    // 第二优先：高德 API（备用，仅当离线失败时）
    const amapResult = await reverseGeocodeAmap(lng, lat)
    if (amapResult) {
      console.log('[地理编码] 高德API成功:', amapResult.province, amapResult.city)
      return amapResult
    }

    // 如果都失败，返回离线结果（即使置信度低）
    if (offlineResult) {
      console.log('[地理编码] 使用低置信度离线结果:', offlineResult.province)
      return {
        province: offlineResult.province,
        city: offlineResult.city,
        district: '',
        formattedAddress: `${offlineResult.province}${offlineResult.city}`,
        source: 'offline-low-confidence'
      }
    }

    return null
  } catch (error) {
    console.error('[地理编码] 请求失败:', error.message)
    
    // 尝试离线兜底
    try {
      const offlineResult = offlineReverseGeocode(lng, lat)
      if (offlineResult) {
        return {
          province: offlineResult.province,
          city: offlineResult.city,
          district: '',
          source: 'offline-fallback'
        }
      }
    } catch (e) {}
    
    return null
  }
}

/**
 * 高德 API 逆地理编码（备用）
 */
async function reverseGeocodeAmap(lng, lat) {
  const AMAP_KEY = process.env.AMAP_KEY || '6f11346662763d1fe0fc63ea12b2ff86'
  const AMAP_GEO_URL = 'https://restapi.amap.com/v3/geocode/regeo'

  try {
    const response = await axiosInstance.get(AMAP_GEO_URL, {
      params: {
        key: AMAP_KEY,
        location: `${lng},${lat}`,
        extensions: 'base',
        output: 'json'
      },
      timeout: 3000
    })

    if (response.data.status === '1' && response.data.regeocode) {
      const address = response.data.regeocode.addressComponent
      
      let province = address.province || ''
      let city = address.city
      
      // 处理直辖市
      if (!city || (Array.isArray(city) && city.length === 0)) {
        city = province
      }
      
      return {
        province: province,
        city: city,
        district: address.district || '',
        formattedAddress: response.data.regeocode.formatted_address || '',
        source: 'amap'
      }
    }

    return null
  } catch (error) {
    logger.debug('[高德API] 请求失败:', error.message)
    return null
  }
}

// ============== IP 定位 ==============

/**
 * 获取客户端IP
 */
export function getClientIP(req) {
  let ip = req.headers['x-forwarded-for'] ||
           req.headers['x-real-ip'] ||
           req.connection?.remoteAddress ||
           req.socket?.remoteAddress ||
           ''

  if (ip.includes(',')) {
    ip = ip.split(',')[0].trim()
  }

  if (ip.startsWith('::ffff:')) {
    ip = ip.substring(7)
  }

  return ip || '127.0.0.1'
}

/**
 * IP 归属地查询
 * 
 * 优先级：
 * 1. ip-api.com（免费，支持中文）
 * 2. ipapi.co（备用）
 * 
 * @param {string} ip IP地址
 * @returns {Promise<{province: string, city: string}>}
 */
export async function getIPLocation(ip) {
  // 跳过本地 IP
  if (ip === '127.0.0.1' || ip === '::1' || ip.startsWith('192.168.') || ip.startsWith('10.') || ip.startsWith('172.')) {
    return null
  }

  // 第一优先：ip-api.com（支持中文，免费）
  let location = await getIPLocationIpApi(ip)
  if (location && location.province) {
    return location
  }

  // 第二优先：ipapi.co
  location = await getIPLocationIpapi(ip)
  if (location && location.province) {
    return location
  }

  return null
}

/**
 * ip-api.com 查询（主）
 * 免费版：45次/分钟，支持中文
 */
async function getIPLocationIpApi(ip) {
  try {
    const response = await axios.get(`http://ip-api.com/json/${ip}?lang=zh-CN`, {
      timeout: 3000
    })

    if (response.data && response.data.status === 'success') {
      const result = {
        province: response.data.regionName || '',
        city: response.data.city || '',
        country: response.data.country || '',
        isp: response.data.isp || ''
      }
      
      // 过滤掉不准确的定位（如香港、澳门的 IP 被误判）
      if (result.country === '香港' || result.country === '澳门') {
        // 这些可能是云服务器出口 IP，不准确
        logger.debug(`[IP定位] 跳过 ${result.country} IP: ${ip}`)
        return null
      }
      
      logger.debug(`[IP定位] ip-api.com 成功: ${ip} -> ${result.province} ${result.city}`)
      return result
    }
    return null
  } catch (error) {
    logger.debug('[IP定位] ip-api.com 失败:', error.message)
    return null
  }
}

/**
 * ipapi.co 查询（备用）
 */
async function getIPLocationIpapi(ip) {
  try {
    const response = await axios.get(`https://ipapi.co/${ip}/json/`, {
      timeout: 3000
    })

    if (response.data && !response.data.error) {
      const result = {
        province: response.data.region || '',
        city: response.data.city || '',
        country: response.data.country_name || ''
      }
      
      logger.debug(`[IP定位] ipapi.co 成功: ${ip} -> ${result.province} ${result.city}`)
      return result
    }
    return null
  } catch (error) {
    logger.debug('[IP定位] ipapi.co 失败:', error.message)
    return null
  }
}

/**
 * 校验 GPS 位置与 IP 归属地是否匹配
 */
export function validateLocation(gpsProvince, ipProvince) {
  if (!gpsProvince || !ipProvince) return true

  const normalize = (str) => str.replace(/省|市|自治区|特别行政区|壮族|回族|维吾尔/g, '')
  const gpsNorm = normalize(gpsProvince)
  const ipNorm = normalize(ipProvince)

  return gpsNorm.includes(ipNorm) || ipNorm.includes(gpsNorm)
}

export default {
  reverseGeocode,
  getClientIP,
  getIPLocation,
  validateLocation
}
