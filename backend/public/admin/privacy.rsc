n":[["$","strong",null,{"children":"身份信息"}],"：提现时可能需要实名认证信息"]}],["$","li",null,{"children":[["$","strong",null,{"children":"任务信息"}],"：平台昵称、任务截图等证明材料"]}],["$","li",null,{"children":[["$","strong",null,{"children":"设备信息"}],"：您领取任务时的地理位置信息（城市、省份）"]}]]}],["$","h3",null,{"children":"2.2 我们自动收集的信息"}],["$","p",null,{"children":"当您使用我们的服务时，我们会自动收集以下信息："}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"设备信息"}],"：设备型号、操作系统版本、浏览器类型"]}],["$","li",null,{"children":[["$","strong",null,{"children":"日志信息"}],"：IP地址、访问时间、访问页面、操作记录"]}],["$","li",null,{"children":[["$","strong",null,{"children":"Cookie和类似技术"}],"：用于维持登录状态和优化用户体验"]}]]}],["$","h3",null,{"children":"2.3 第三方来源的信息"}],["$","p",null,{"children":"我们可能从第三方获取您的以下信息："}],"$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32","$L33","$L34","$L35","$L36","$L37"]}]]}],"$L38"]}]}],null,"$L39"]}],{},null,false,false]},null,false,false]},null,false,false],"$L3a",false]],"m":"$undefined","G":["$3b",[]],"S":true}
