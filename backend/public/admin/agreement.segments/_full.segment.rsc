19:["$","ul",null,{"children":[["$","li",null,{"children":"C端推广：邀请好友注册并完成任务，可获得好友任务收益的一定比例作为奖励"}],["$","li",null,{"children":"B端推广：邀请新发布者入驻，可获得其发布任务收益的一定比例作为奖励"}]]}]
1a:["$","p",null,{"children":"6.2 推广限制："}]
