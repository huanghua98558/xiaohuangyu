ull,{"children":[["$","li",null,{"children":"任务发布与领取服务"}],["$","li",null,{"children":"任务审核与结算服务"}],["$","li",null,{"children":"积分奖励与提现服务"}],["$","li",null,{"children":"推广返佣服务"}],["$","li",null,{"children":"排行榜与等级系统"}]]}],["$","p",null,{"children":"2.2 本平台提供的任务类型为：观看视频，评论真实的视频观看感受并提交。"}],["$","p",null,{"children":"2.3 本平台保留随时变更、中断或终止部分或全部服务的权利。"}],["$","h2",null,{"children":"三、账号注册与使用"}],["$","p",null,{"children":"3.1 用户注册时，应按照注册页面提示填写真实、准确、完整的个人资料。"}],["$","p",null,{"children":"3.2 用户应妥善保管账号及密码，因账号密码泄露造成的损失由用户自行承担。"}],["$","p",null,{"children":"3.3 用户不得将账号转让、出借给他人使用。因账号转让、出借造成的损失，由用户自行承担。"}],"$L5","$L6","$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b","$L1c","$L1d","$L1e","$L1f","$L20","$L21","$L22","$L23","$L24","$L25","$L26","$L27","$L28","$L29","$L2a","$L2b","$L2c","$L2d","$L2e","$L2f","$L30","$L31","$L32"]}]]}],"$L33"]}]}],null,"$L34"]}],{},null,false,false]},null,false,false]},null,false,false],"$L35",false]],"m":"$undefined","G":["$36",[]],"S":true}
