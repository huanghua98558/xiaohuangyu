# ============================================================
# 小黄鱼用户端前端 - 环境变量配置示例
# ============================================================

# API 服务地址
VITE_API_URL=http://localhost:3001/api

# WebSocket 服务地址
VITE_WS_URL=ws://localhost:3001

# 环境
VITE_APP_ENV=production

# 应用名称
VITE_APP_NAME=小黄鱼任务中心

# PWA 配置
VITE_PWA_ENABLED=true

# 地图配置（可选）
VITE_MAP_KEY=your-map-key

# 统计配置（可选）
VITE_ANALYTICS_ENABLED=false
