/**
 * 图片压缩函数（无感压缩）
 * @param {File} file - 要压缩的图片文件
 * @param {Object} options - 压缩选项
 * @param {number} options.maxSize - 最大文件大小（字节），超过此大小才压缩，默认 500KB
 * @param {number} options.maxWidth - 最大宽度，默认 1920
 * @param {number} options.maxHeight - 最大高度，默认 1920
 * @param {number} options.quality - 压缩质量（0-1），默认 0.8
 * @returns {Promise<File>} - 压缩后的文件
 */
export async function uploadFile(file, timeout = 60000) {
  console.log('[uploadFile] 开始上传, 原始大小:', (file.size / 1024 / 1024).toFixed(2) + 'MB')
  
  // 先压缩图片
  const compressedFile = await compressImage(file)
  
  const formData = new FormData()
  formData.append('file', compressedFile)
  
  const token = localStorage.getItem(TOKEN_KEY)
  console.log('[uploadFile] token存在:', !!token)
  
  // 创建 AbortController 用于超时控制
  const controller = new AbortController()
  const timeoutId = setTimeout(() => {
    controller.abort()
  }, timeout)
  
  try {
    const res = await fetch(BASE + '/upload/single', {
      method: 'POST',
      headers: token ? { 'Authorization': `Bearer ${token}` } : {},
      body: formData,
      signal: controller.signal
    })
    
    clearTimeout(timeoutId)
    
    // 检查 HTTP 状态
    if (!res.ok) {
      let errorMsg = '上传失败'
      try {
        const errorJson = await res.json()
        errorMsg = errorJson.message || errorMsg
      } catch (e) {
        errorMsg = `服务器错误 (${res.status})`
      }
      throw new Error(errorMsg)
    }
    
    const json = await res.json()
    console.log('[上传响应]', json)
    
    if (json.code === 0) {
      console.log('[上传返回数据]', json.data)
      return json.data
    }
    
    throw new Error(json.message || '上传失败')
  } catch (e) {
    clearTimeout(timeoutId)
    
    // 处理超时
    if (e.name === 'AbortError') {
      throw new Error('上传超时，请检查网络连接后重试')
    }
    
    // 处理网络错误
    if (e.message === 'Failed to fetch' || e.message.includes('NetworkError')) {
      throw new Error('网络连接失败，请检查网络后重试')
    }
    
    throw e
  }
}

export async function uploadFiles(files, timeout = 120000) {
  const formData = new FormData()
  files.forEach(file => formData.append('files', file))
  
  const token = localStorage.getItem(TOKEN_KEY)
  
  // 创建 AbortController 用于超时控制
  const controller = new AbortController()
  const timeoutId = setTimeout(() => {
    controller.abort()
  }, timeout)
  
  try {
    const res = await fetch(BASE + '/upload/multiple', {
      method: 'POST',
      headers: token ? { 'Authorization': `Bearer ${token}` } : {},
      body: formData,
      signal: controller.signal
    })
    
    clearTimeout(timeoutId)
    
    // 检查 HTTP 状态
    if (!res.ok) {
      let errorMsg = '上传失败'
      try {
        const errorJson = await res.json()
        errorMsg = errorJson.message || errorMsg
      } catch (e) {
        errorMsg = `服务器错误 (${res.status})`
      }
      throw new Error(errorMsg)
    }
    
    const json = await res.json()
    
    if (json.code === 0) {
      return json.data
    }
    
    throw new Error(json.message || '上传失败')
  } catch (e) {
    clearTimeout(timeoutId)
    
    // 处理超时
    if (e.name === 'AbortError') {
      throw new Error('上传超时，请检查网络连接后重试')
    }
    
    // 处理网络错误
    if (e.message === 'Failed to fetch' || e.message.includes('NetworkError')) {
      throw new Error('网络连接失败，请检查网络后重试')
    }
    
    throw e
  }
}

