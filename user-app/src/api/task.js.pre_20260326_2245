export async function register(username, password, phone = '', inviteCode = '', agreedToPrivacy = true, agreedToTerms = true) {
  const body = { 
    username, 
    password, 
    phone,
    agreedToPrivacy,
    agreedToTerms
  }
  if (inviteCode) body.inviteCode = inviteCode
  const { data, message } = await request('/auth/register', {
    method: 'POST',
    body: JSON.stringify(body),
  })
  return { data, message }
}

