# ============================================================
# 小黄鱼管理后台前端 - 环境变量配置示例
# ============================================================

# API 服务地址
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# WebSocket 服务地址
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# 环境
NEXT_PUBLIC_APP_ENV=production

# 应用名称
NEXT_PUBLIC_APP_NAME=小黄鱼管理中心
