'use client'

import { useState, useRef, useEffect, useCallback } from 'react'
import { useRouter } from 'next/navigation'
import { TASK_ACTIONS, TASK_ACTION_NAMES, PLATFORMS, PLATFORM_NAMES, getActionName as getActionNameConst, getPlatformName as getPlatformNameConst } from '@/constants/taskActions'
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card'
import { Button } from '@/components/ui/button'
import { Input } from '@/components/ui/input'
import { Textarea } from '@/components/ui/textarea'
import { Badge } from '@/components/ui/badge'
import { ScrollArea } from '@/components/ui/scroll-area'
import { Separator } from '@/components/ui/separator'
import {
  Dialog,
  DialogContent,
  DialogHeader,
  DialogTitle,
  DialogFooter,
  DialogTrigger,
  DialogDescription,
} from '@/components/ui/dialog'
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs'
import {
  AlertDialog,
  AlertDialogAction,
  AlertDialogCancel,
  AlertDialogContent,
  AlertDialogDescription,
  AlertDialogFooter,
  AlertDialogHeader,
  AlertDialogTitle,
} from '@/components/ui/alert-dialog'
import { Label } from '@/components/ui/label'
import { 
  Send, 
  Sparkles, 
  Plus,
  MessageSquare,
  Settings,
  History,
  FileText,
  Zap,
  Copy,
  Trash2,
  MoreHorizontal,
  Clock,
  ChevronRight,
  Pencil,
  Check,
  X,
  Loader2
} from 'lucide-react'
import { toast } from 'sonner'
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuSeparator,
  DropdownMenuTrigger,
} from '@/components/ui/dropdown-menu'

// 运行时动态获取API地址（不依赖构建时环境变量）
const getApiBase = (): string => {
  if (typeof window === 'undefined') return ''
  
  const { hostname, port } = window.location
  // 本地开发环境：直接访问后端 8080 端口
  if (hostname === 'localhost' || hostname === '127.0.0.1') {
    return 'http://localhost:8080'
  }
  // 远程/沙盒环境：使用相对路径，由代理转发到后端
  return ''
}

// 消息类型
interface Message {
  id: string
  role: 'user' | 'assistant' | 'system'
  content: string
  timestamp: Date
  status?: 'loading' | 'success' | 'error'
  taskData?: any
}

// 会话类型
interface Conversation {
  id: number
  title: string
  type: string
  status: string
  created_at: string
  updated_at: string
  lastMessage?: {
    content: string
    created_at: string
  }
}

// 快捷模板类型
interface QuickTemplate {
  id: number | string
  name: string
  platform: string
  platformName?: string
  action: string
  reward: number
  remain: number  // 任务需要人数
  desc: string
  timeLimitMinutes: number
  isDefault?: boolean
  canEdit?: boolean
}

export default function AIPublisherPage() {
  const router = useRouter()
  
  // 会话状态
  const [conversations, setConversations] = useState<Conversation[]>([])
  const [currentConversation, setCurrentConversation] = useState<Conversation | null>(null)
  const [messages, setMessages] = useState<Message[]>([])
  const [input, setInput] = useState('')
  const [isLoading, setIsLoading] = useState(false)
  const [isLoadingHistory, setIsLoadingHistory] = useState(false)
  const [sidebarOpen, setSidebarOpen] = useState(true)
  
  // 模板状态
  const [templates, setTemplates] = useState<QuickTemplate[]>([])
  const [isLoadingTemplates, setIsLoadingTemplates] = useState(false)
  const [showTemplateDialog, setShowTemplateDialog] = useState(false)
  const [showTemplateEditDialog, setShowTemplateEditDialog] = useState(false)
  const [editingTemplate, setEditingTemplate] = useState<QuickTemplate | null>(null)
  const [templateForm, setTemplateForm] = useState<Partial<QuickTemplate>>({})
  const [templateDialogTab, setTemplateDialogTab] = useState<string>('list')
  
  // 删除确认
  const [deleteConversationId, setDeleteConversationId] = useState<number | null>(null)
  
  const messagesEndRef = useRef<HTMLDivElement>(null)
  const inputRef = useRef<HTMLTextAreaElement>(null)

  // 滚动到底部
  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' })
  }

  useEffect(() => {
    scrollToBottom()
  }, [messages])

  // 从 API 加载模板
  const loadTemplates = useCallback(async () => {
    setIsLoadingTemplates(true)
    try {
      const token = localStorage.getItem('admin_token')
      const res = await fetch(`${getApiBase()}/api/ai/templates`, {
        headers: token ? { 'Authorization': `Bearer ${token}` } : {}
      })
      const data = await res.json()
      if (data.code === 200 && data.data) {
        setTemplates(data.data.map((t: any) => ({
          id: t.id,
          name: t.name,
          platform: t.platform,
          platformName: t.platformName,
          action: t.action,
          reward: t.reward,
          remain: t.remain,
          desc: t.description || '',
          timeLimitMinutes: t.timeLimitMinutes,
          isDefault: t.isDefault,
          canEdit: t.canEdit
        })))
      }
    } catch (error) {
      console.error('加载模板失败:', error)
    } finally {
      setIsLoadingTemplates(false)
    }
  }, [])

  // 初始化加载
  useEffect(() => {
    loadTemplates()
  }, [loadTemplates])

  // 加载会话列表
  const loadConversations = useCallback(async () => {
    try {
      const token = localStorage.getItem('admin_token')
      const res = await fetch(`${getApiBase()}/api/ai/conversations?type=publisher&pageSize=50`, {
        headers: token ? { 'Authorization': `Bearer ${token}` } : {}
      })
      const data = await res.json()
      if (data.code === 200 && data.data?.list) {
        setConversations(data.data.list)
      }
    } catch (error) {
      console.error('加载会话列表失败:', error)
    }
  }, [])

  // 初始化加载
  useEffect(() => {
    loadConversations()
    loadTemplates()
  }, [loadConversations, loadTemplates])

  // 添加欢迎消息
  useEffect(() => {
    if (messages.length === 0 && !currentConversation) {
      setMessages([{
        id: 'welcome',
        role: 'assistant',
        content: `👋 我是AI发布助手！

**指令模式已启用**，你可以：
- 📎 **发送链接** → 自动解析并发布任务
- 🔍 **查询统计** → 输入"查询"查看数据
- ⏰ **发送提醒** → 输入"提醒 @用户 内容"
- 📋 **选择模板** → 点击右侧快捷模板

**支持的链接格式**：
- 抖音：\`https://v.douyin.com/xxx\`
- 小红书：\`https://www.xiaohongshu.com/xxx\`
- 快手：\`https://v.kuaishou.com/xxx\`
- B站：\`https://www.bilibili.com/xxx\`

直接粘贴链接，我会自动解析并发布！`,
        timestamp: new Date(),
        status: 'success'
      }])
    }
  }, [currentConversation, messages.length])

  // 创建新会话
  const createNewConversation = async () => {
    try {
      const token = localStorage.getItem('admin_token')
      const res = await fetch(`${getApiBase()}/api/ai/conversations`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          ...(token ? { 'Authorization': `Bearer ${token}` } : {})
        },
        body: JSON.stringify({
          type: 'publisher',
          title: `发布助手 - ${new Date().toLocaleString('zh-CN', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}`
        })
      })
      const data = await res.json()
      if (data.code === 200 && data.data) {
        setCurrentConversation(data.data)
        setMessages([{
          id: 'welcome',
          role: 'assistant',
          content: '新会话已创建，请发送链接或指令开始发布任务！',
          timestamp: new Date(),
          status: 'success'
        }])
        await loadConversations()
      }
    } catch (error) {
      toast.error('创建会话失败')
    }
  }

  // 加载会话历史
  const loadConversationHistory = async (conversationId: number) => {
    setIsLoadingHistory(true)
    try {
      const token = localStorage.getItem('admin_token')
      const res = await fetch(`${getApiBase()}/api/ai/conversations/${conversationId}`, {
        headers: token ? { 'Authorization': `Bearer ${token}` } : {}
      })
      const data = await res.json()
      if (data.code === 200 && data.data) {
        setCurrentConversation(data.data)
        const historyMessages = (data.data.messages || []).map((m: any) => ({
          id: m.id.toString(),
          role: m.role,
          content: m.content,
          timestamp: new Date(m.created_at),
          status: 'success'
        }))
        setMessages(historyMessages.length > 0 ? historyMessages : [{
          id: 'welcome',
          role: 'assistant',
          content: '会话已加载，请继续对话！',
          timestamp: new Date(),
          status: 'success'
        }])
      }
    } catch (error) {
      toast.error('加载会话历史失败')
    } finally {
      setIsLoadingHistory(false)
    }
  }

  // 删除会话
  const deleteConversation = async (conversationId: number) => {
    try {
      const token = localStorage.getItem('admin_token')
      const res = await fetch(`${getApiBase()}/api/ai/conversations/${conversationId}`, {
        method: 'DELETE',
        headers: token ? { 'Authorization': `Bearer ${token}` } : {}
      })
      const data = await res.json()
      if (data.code === 200) {
        setConversations(prev => prev.filter(c => c.id !== conversationId))
        if (currentConversation?.id === conversationId) {
          setCurrentConversation(null)
          setMessages([])
        }
        toast.success('会话已删除')
      }
    } catch (error) {
      toast.error('删除会话失败')
    }
    setDeleteConversationId(null)
  }

  // 发送消息
  const sendMessage = async () => {
    if (!input.trim() || isLoading) return

    const userMessage: Message = {
      id: Date.now().toString(),
      role: 'user',
      content: input.trim(),
      timestamp: new Date()
    }

    setMessages(prev => [...prev, userMessage])
    setInput('')
    setIsLoading(true)

    // 添加加载消息
    const loadingId = (Date.now() + 1).toString()
    setMessages(prev => [...prev, {
      id: loadingId,
      role: 'assistant',
      content: '正在处理...',
      timestamp: new Date(),
      status: 'loading'
    }])

    try {
      const token = typeof window !== 'undefined' ? localStorage.getItem('admin_token') : null
      
      const response = await fetch(`${getApiBase()}/api/ai/publisher/chat`, {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          ...(token ? { 'Authorization': `Bearer ${token}` } : {})
        },
        body: JSON.stringify({ 
          message: userMessage.content,
          conversationId: currentConversation?.id 
        })
      })

      if (!response.ok) {
        let errorMsg = '请求失败'
        try {
          const errorData = await response.json()
          errorMsg = errorData.message || errorMsg
        } catch (e) {}
        throw new Error(errorMsg)
      }

      // 流式读取响应
      const reader = response.body?.getReader()
      const decoder = new TextDecoder()
      let fullContent = ''

      // 移除加载消息
      setMessages(prev => prev.filter(m => m.id !== loadingId))

      if (reader) {
        while (true) {
          const { done, value } = await reader.read()
          if (done) break

          const chunk = decoder.decode(value)
          const lines = chunk.split('\n')

          for (const line of lines) {
            if (line.startsWith('data: ')) {
              const data = line.slice(6)
              if (data === '[DONE]') continue
              
              try {
                const parsed = JSON.parse(data)
                if (parsed.content) {
                  fullContent += parsed.content
                  
                  setMessages(prev => {
                    const lastMsg = prev[prev.length - 1]
                    if (lastMsg.role === 'assistant' && lastMsg.id === loadingId) {
                      return [...prev.slice(0, -1), { ...lastMsg, content: fullContent, status: 'success' }]
                    } else {
                      return [...prev, {
                        id: loadingId,
                        role: 'assistant',
                        content: fullContent,
                        timestamp: new Date(),
                        status: 'success'
                      }]
                    }
                  })
                }
              } catch (e) {}
            }
          }
        }
      }

      // 刷新会话列表
      await loadConversations()

    } catch (error: any) {
      setMessages(prev => prev.filter(m => m.id !== loadingId))
      
      setMessages(prev => [...prev, {
        id: (Date.now() + 2).toString(),
        role: 'assistant',
        content: `❌ 处理失败：${error.message}`,
        timestamp: new Date(),
        status: 'error'
      }])
    } finally {
      setIsLoading(false)
    }
  }

  // 使用模板
  const useTemplate = (template: QuickTemplate) => {
    const actionName = getActionNameConst(template.action)
    const platformName = template.platformName || getPlatformNameConst(template.platform)
    setInput(`使用模板：${template.name}
平台：${platformName}
操作：${actionName}
奖励：${template.reward}积分
人数：${template.remain}人
时长：${template.timeLimitMinutes}分钟
说明：${template.desc}

请提供任务链接：`)
    inputRef.current?.focus()
  }

  // 复制消息
  const copyMessage = (content: string) => {
    navigator.clipboard.writeText(content)
    toast.success('已复制到剪贴板')
  }

  // 清空当前对话
  const clearCurrentChat = () => {
    setMessages([{
      id: Date.now().toString(),
      role: 'assistant',
      content: '对话已清空。继续发送链接或命令吧！',
      timestamp: new Date(),
      status: 'success'
    }])
  }

  // 打开模板编辑
  const openTemplateEdit = (template?: QuickTemplate) => {
    if (template) {
      setEditingTemplate(template)
      setTemplateForm({ ...template })
    } else {
      setEditingTemplate(null)
      setTemplateForm({
        id: `template_${Date.now()}`,
        name: '',
        platform: PLATFORMS.DOUYIN,
        action: TASK_ACTIONS.SHORT_VIDEO_RESEARCH,
        reward: 30,
        remain: 10,
        desc: '',
        timeLimitMinutes: 15
      })
    }
    setShowTemplateEditDialog(true)
  }

  // 保存模板（调用 API）
  const saveTemplate = async () => {
    if (!templateForm.name || !templateForm.platform || !templateForm.action) {
      toast.error('请填写完整信息')
      return
    }

    try {
      const token = localStorage.getItem('admin_token')
      const isEditing = editingTemplate && typeof editingTemplate.id === 'number'
      
      const url = isEditing 
        ? `${getApiBase()}/api/ai/templates/${editingTemplate.id}`
        : `${getApiBase()}/api/ai/templates`
      
      const method = isEditing ? 'PUT' : 'POST'
      
      const body = {
        name: templateForm.name,
        platform: templateForm.platform,
        action: templateForm.action,
        reward: templateForm.reward || 30,
        remain: templateForm.remain || 10,
        timeLimitMinutes: templateForm.timeLimitMinutes || 15,
        description: templateForm.desc || ''
      }
      
      const res = await fetch(url, {
        method,
        headers: {
          'Content-Type': 'application/json',
          ...(token ? { 'Authorization': `Bearer ${token}` } : {})
        },
        body: JSON.stringify(body)
      })
      
      const data = await res.json()
      
      if (data.code === 200) {
        toast.success(isEditing ? '模板已更新' : '模板已添加')
        setShowTemplateEditDialog(false)
        setEditingTemplate(null)
        setTemplateForm({})
        await loadTemplates() // 刷新模板列表
      } else {
        toast.error(data.message || '保存失败')
      }
    } catch (error) {
      console.error('保存模板失败:', error)
      toast.error('保存失败')
    }
  }

  // 删除模板（调用 API）
  const deleteTemplate = async (templateId: number | string) => {
    // 如果是默认模板，不允许删除
    const template = templates.find(t => t.id === templateId)
    if (template?.isDefault) {
      toast.error('默认模板不能删除')
      return
    }
    
    try {
      const token = localStorage.getItem('admin_token')
      const res = await fetch(`${getApiBase()}/api/ai/templates/${templateId}`, {
        method: 'DELETE',
        headers: token ? { 'Authorization': `Bearer ${token}` } : {}
      })
      
      const data = await res.json()
      
      if (data.code === 200) {
        toast.success('模板已删除')
        await loadTemplates() // 刷新模板列表
      } else {
        toast.error(data.message || '删除失败')
      }
    } catch (error) {
      console.error('删除模板失败:', error)
      toast.error('删除失败')
    }
  }

  // 格式化时间
  const formatTime = (date: Date | string) => {
    const d = typeof date === 'string' ? new Date(date) : date
    return d.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })
  }

  // 格式化日期时间
  const formatDateTime = (date: string) => {
    return new Date(date).toLocaleString('zh-CN', { 
      month: 'short', 
      day: 'numeric',
      hour: '2-digit', 
      minute: '2-digit' 
    })
  }

  // 获取平台显示名称
  const getPlatformName = (platform: string) => {
    // 使用常量文件中的定义，兼容旧数据
    if (platform === 'bilibili') return 'B站'
    return getPlatformNameConst(platform)
  }

  // 获取操作类型显示名称
  const getActionName = (action: string) => {
    return getActionNameConst(action)
  }

  return (
    <div className="h-[calc(100vh-4rem)] flex bg-background relative">
      {/* 移动端遮罩层 */}
      {sidebarOpen && (
        <div 
          className="fixed inset-0 bg-black/50 z-40 md:hidden" 
          onClick={() => setSidebarOpen(false)}
        />
      )}
      
      {/* 左侧边栏 - 会话列表 */}
      <div className={`${sidebarOpen ? 'translate-x-0' : '-translate-x-full'} md:translate-x-0 fixed md:relative left-0 top-0 bottom-0 w-72 md:w-64 border-r bg-muted/30 transition-transform duration-300 z-50 md:z-auto flex-shrink-0 overflow-hidden`}>
        <div className="h-full flex flex-col">
          {/* 侧边栏头部 */}
          <div className="p-3 border-b flex items-center justify-between">
            <span className="font-medium text-sm">会话历史</span>
            <div className="flex items-center gap-1">
              <Button variant="ghost" size="sm" className="h-7 w-7 p-0" onClick={createNewConversation}>
                <Plus className="w-4 h-4" />
              </Button>
              <Button variant="ghost" size="sm" className="h-7 w-7 p-0 md:hidden" onClick={() => setSidebarOpen(false)}>
                <X className="w-4 h-4" />
              </Button>
            </div>
          </div>
          
          {/* 会话列表 */}
          <ScrollArea className="flex-1">
            <div className="p-2 space-y-1">
              {conversations.length === 0 ? (
                <div className="text-center text-sm text-muted-foreground py-8">
                  <History className="w-8 h-8 mx-auto mb-2 opacity-50" />
                  <p>暂无历史会话</p>
                  <p className="text-xs mt-1">发送消息后自动创建</p>
                </div>
              ) : (
                conversations.map((conv) => (
                  <div
                    key={conv.id}
                    className={`group p-2 rounded-lg cursor-pointer transition-colors ${
                      currentConversation?.id === conv.id 
                        ? 'bg-primary/10 text-primary' 
                        : 'hover:bg-muted'
                    }`}
                    onClick={() => loadConversationHistory(conv.id)}
                  >
                    <div className="flex items-start justify-between gap-2">
                      <div className="flex-1 min-w-0">
                        <p className="text-sm font-medium truncate">{conv.title}</p>
                        {conv.lastMessage && (
                          <p className="text-xs text-muted-foreground truncate mt-0.5">
                            {conv.lastMessage.content.slice(0, 30)}...
                          </p>
                        )}
                      </div>
                      <Button
                        variant="ghost"
                        size="sm"
                        className="h-6 w-6 p-0 opacity-0 group-hover:opacity-100"
                        onClick={(e) => {
                          e.stopPropagation()
                          setDeleteConversationId(conv.id)
                        }}
                      >
                        <Trash2 className="w-3 h-3 text-muted-foreground hover:text-destructive" />
                      </Button>
                    </div>
                    <p className="text-xs text-muted-foreground mt-1">
                      {formatDateTime(conv.updated_at)}
                    </p>
                  </div>
                ))
              )}
            </div>
          </ScrollArea>
        </div>
      </div>

      {/* 主区域 */}
      <div className="flex-1 flex flex-col min-w-0 relative">
        {/* 顶部栏 */}
        <div className="border-b px-3 md:px-4 py-3 flex items-center justify-between bg-background">
          <div className="flex items-center gap-2 md:gap-3">
            <Button 
              variant="ghost" 
              size="sm" 
              className="h-8 w-8 p-0"
              onClick={() => setSidebarOpen(!sidebarOpen)}
            >
              <History className="w-4 h-4" />
            </Button>
            <div className="flex items-center gap-2">
              <div className="w-8 h-8 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center shrink-0">
                <Sparkles className="w-4 h-4 text-white" />
              </div>
              <p className="text-xs text-muted-foreground hidden sm:block">
                {currentConversation ? `会话 #${currentConversation.id}` : '新会话'}
              </p>
            </div>
          </div>
          <div className="flex items-center gap-1 md:gap-2">
            <Badge variant="secondary" className="gap-1 text-xs">
              <div className="w-2 h-2 rounded-full bg-green-500 animate-pulse" />
              <span className="hidden sm:inline">在线</span>
            </Badge>
            <Button variant="outline" size="sm" className="h-8" onClick={() => router.push('/ai-management')}>
              <Settings className="w-4 h-4 md:mr-1" />
              <span className="hidden md:inline">配置</span>
            </Button>
            {/* 移动端模板按钮 */}
            <Button variant="outline" size="sm" className="h-8 md:hidden" onClick={() => setShowTemplateDialog(true)}>
              <FileText className="w-4 h-4" />
            </Button>
          </div>
        </div>

        {/* 消息区域 */}
        <ScrollArea className="flex-1 p-3 md:p-4 md:pr-60">
          {isLoadingHistory ? (
            <div className="flex items-center justify-center h-full">
              <Loader2 className="w-6 h-6 animate-spin text-muted-foreground" />
            </div>
          ) : (
            <div className="max-w-3xl mx-auto space-y-4">
              {messages.map((message) => (
                <div
                  key={message.id}
                  className={`flex ${message.role === 'user' ? 'justify-end' : 'justify-start'}`}
                >
                  <div
                    className={`max-w-[85%] rounded-2xl px-4 py-3 ${
                      message.role === 'user'
                        ? 'bg-primary text-primary-foreground'
                        : message.status === 'error'
                        ? 'bg-destructive/10 text-destructive'
                        : 'bg-muted'
                    }`}
                  >
                    <div className="prose prose-sm dark:prose-invert max-w-none">
                      {message.content.split('\n').map((line, i) => (
                        <p key={i} className="mb-1 last:mb-0 whitespace-pre-wrap">
                          {line.startsWith('**') && line.endsWith('**') ? (
                            <strong>{line.slice(2, -2)}</strong>
                          ) : line.startsWith('- ') ? (
                            <span className="flex items-start gap-1">
                              <span className="text-muted-foreground">•</span>
                              <span>{line.slice(2)}</span>
                            </span>
                          ) : line.startsWith('```') ? (
                            <code className="bg-background/50 px-1 rounded text-sm">
                              {line.replace(/```/g, '')}
                            </code>
                          ) : (
                            line
                          )}
                        </p>
                      ))}
                    </div>
                    <div className="flex items-center justify-between mt-2 pt-2 border-t border-border/50">
                      <span className="text-xs opacity-60">
                        {formatTime(message.timestamp)}
                      </span>
                      {message.role === 'assistant' && message.status !== 'loading' && (
                        <Button
                          variant="ghost"
                          size="sm"
                          className="h-6 px-2"
                          onClick={() => copyMessage(message.content)}
                        >
                          <Copy className="w-3 h-3" />
                        </Button>
                      )}
                    </div>
                  </div>
                </div>
              ))}
              <div ref={messagesEndRef} />
            </div>
          )}
        </ScrollArea>

        {/* 快捷操作栏 */}
        <div className="border-t bg-background px-3 md:px-4 py-2 md:pr-60">
          <div className="max-w-3xl mx-auto flex items-center gap-2 overflow-x-auto">
            <Button
              variant="outline"
              size="sm"
              className="gap-1 shrink-0 text-xs md:text-sm"
              onClick={() => setShowTemplateDialog(true)}
            >
              <FileText className="w-3.5 h-3.5 md:w-4 md:h-4" />
              <span className="hidden sm:inline">快捷</span>模板
            </Button>
            <Separator orientation="vertical" className="h-6 hidden sm:block" />
            <Button
              variant="ghost"
              size="sm"
              className="gap-1 shrink-0 text-xs hidden sm:flex"
              onClick={() => setInput('查询今日发布统计')}
            >
              <Zap className="w-3 h-3" />
              今日统计
            </Button>
            <Button
              variant="ghost"
              size="sm"
              className="gap-1 shrink-0 text-xs hidden sm:flex"
              onClick={() => setInput('查询待审核任务')}
            >
              <Clock className="w-3 h-3" />
              待审核
            </Button>
            <div className="flex-1" />
            <Button
              variant="ghost"
              size="sm"
              className="gap-1 text-muted-foreground text-xs"
              onClick={clearCurrentChat}
            >
              <Trash2 className="w-3.5 h-3.5" />
            </Button>
          </div>
        </div>

        {/* 输入区域 */}
        <div className="border-t bg-background px-3 md:px-4 py-3 md:pr-60">
          <div className="max-w-3xl mx-auto">
            <div className="flex items-end gap-2 md:gap-3">
              <div className="flex-1 relative">
                <Textarea
                  ref={inputRef}
                  value={input}
                  onChange={(e) => setInput(e.target.value)}
                  placeholder="粘贴链接或输入指令... (Shift+Enter换行)"
                  className="min-h-[48px] md:min-h-[52px] max-h-[200px] resize-none pr-11 md:pr-12 text-sm md:text-base"
                  onKeyDown={(e) => {
                    if (e.key === 'Enter' && !e.shiftKey) {
                      e.preventDefault()
                      sendMessage()
                    }
                  }}
                />
                <Button
                  size="icon"
                  className="absolute right-2 bottom-2 h-7 w-7 md:h-8 md:w-8"
                  onClick={sendMessage}
                  disabled={isLoading || !input.trim()}
                >
                  {isLoading ? (
                    <Loader2 className="w-3.5 h-3.5 md:w-4 md:h-4 animate-spin" />
                  ) : (
                    <Send className="w-3.5 h-3.5 md:w-4 md:h-4" />
                  )}
                </Button>
              </div>
            </div>
            <p className="text-xs text-muted-foreground mt-2 text-center hidden sm:block">
              💡 直接粘贴抖音/小红书/快手/B站链接，AI会自动解析并发布任务
            </p>
          </div>
        </div>
      </div>

      {/* 右侧模板面板 - 仅桌面端显示 */}
      <div className="absolute right-0 top-0 bottom-0 w-56 pointer-events-none hidden lg:block">
        <div className="h-full flex flex-col justify-end pb-[140px] pr-2">
          <div className="pointer-events-auto space-y-2">
            {templates.map((template) => (
              <Card
                key={template.id}
                className="cursor-pointer hover:bg-muted transition-colors group shadow-sm bg-background/95 backdrop-blur-sm"
                onClick={() => useTemplate(template)}
              >
                <CardContent className="p-2.5">
                  <div className="flex items-center justify-between mb-0.5">
                    <span className="font-medium text-sm">{template.name}</span>
                    <div className="flex items-center gap-1">
                      <Badge variant="secondary" className="text-xs px-1.5">{template.reward}分</Badge>
                      <Badge variant="outline" className="text-xs px-1.5">{template.remain}人</Badge>
                    </div>
                  </div>
                  <div className="flex items-center gap-2 text-xs text-muted-foreground">
                    <span>{getPlatformName(template.platform)}</span>
                    <span>·</span>
                    <span>{template.timeLimitMinutes}分钟</span>
                  </div>
                  {template.isDefault ? (
                    <Badge variant="outline" className="absolute top-1 right-1 text-[10px] px-1.5 py-0 h-4 bg-muted/50">默认</Badge>
                  ) : (
                    <DropdownMenu>
                      <DropdownMenuTrigger asChild onClick={(e) => e.stopPropagation()}>
                        <Button variant="ghost" size="sm" className="absolute top-1 right-1 h-5 w-5 p-0 opacity-0 group-hover:opacity-100">
                          <MoreHorizontal className="w-3 h-3" />
                        </Button>
                      </DropdownMenuTrigger>
                      <DropdownMenuContent align="end">
                        <DropdownMenuItem onClick={(e) => {
                          e.stopPropagation()
                          openTemplateEdit(template)
                        }}>
                          <Pencil className="w-4 h-4 mr-2" />
                          编辑
                        </DropdownMenuItem>
                        <DropdownMenuSeparator />
                        <DropdownMenuItem 
                          className="text-destructive"
                          onClick={(e) => {
                            e.stopPropagation()
                            deleteTemplate(template.id)
                          }}
                        >
                          <Trash2 className="w-4 h-4 mr-2" />
                          删除
                        </DropdownMenuItem>
                      </DropdownMenuContent>
                    </DropdownMenu>
                  )}
                </CardContent>
              </Card>
            ))}
            <Button 
              variant="outline" 
              size="sm" 
              className="w-full gap-1 text-xs h-7" 
              onClick={() => openTemplateEdit()}
            >
              <Plus className="w-3 h-3" />
              添加模板
            </Button>
          </div>
        </div>
      </div>

      {/* 模板列表对话框 */}
      <Dialog open={showTemplateDialog} onOpenChange={setShowTemplateDialog}>
        <DialogContent className="max-w-lg max-h-[80vh] w-[95vw] md:w-full">
          <DialogHeader>
            <DialogTitle className="flex items-center justify-between">
              <span>快捷模板</span>
              <Button variant="ghost" size="sm" className="h-7 w-7 p-0" onClick={() => {
                setShowTemplateDialog(false)
                openTemplateEdit()
              }}>
                <Plus className="w-4 h-4" />
              </Button>
            </DialogTitle>
            <DialogDescription>
              点击模板快速填充任务信息
            </DialogDescription>
          </DialogHeader>
          <ScrollArea className="max-h-[50vh]">
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-3 py-2 pr-2">
              {templates.map((template) => (
                <Card
                  key={template.id}
                  className="cursor-pointer hover:bg-muted transition-colors group"
                  onClick={() => {
                    useTemplate(template)
                    setShowTemplateDialog(false)
                  }}
                >
                  <CardContent className="p-3">
                    <div className="flex items-center justify-between mb-1">
                      <span className="font-medium text-sm">{template.name}</span>
                      <div className="flex items-center gap-1">
                        <Badge variant="secondary" className="text-xs">{template.reward}分</Badge>
                        <Badge variant="outline" className="text-xs">{template.remain}人</Badge>
                      </div>
                    </div>
                    <p className="text-xs text-muted-foreground line-clamp-1">{template.desc}</p>
                    <div className="flex items-center gap-2 mt-2">
                      <Badge variant="outline" className="text-xs">{getPlatformName(template.platform)}</Badge>
                      <span className="text-xs text-muted-foreground flex items-center gap-1">
                        <Clock className="w-3 h-3" />
                        {template.timeLimitMinutes}分钟
                      </span>
                      {template.isDefault && (
                        <Badge variant="outline" className="text-[10px] ml-auto bg-muted/50">默认</Badge>
                      )}
                    </div>
                    {!template.isDefault && (
                      <div className="flex items-center gap-1 mt-2 opacity-0 group-hover:opacity-100">
                        <Button 
                          variant="ghost" 
                          size="sm" 
                          className="h-6 px-2 text-xs"
                          onClick={(e) => {
                            e.stopPropagation()
                            setShowTemplateDialog(false)
                            openTemplateEdit(template)
                          }}
                        >
                          <Pencil className="w-3 h-3 mr-1" />
                          编辑
                        </Button>
                        <Button 
                          variant="ghost" 
                          size="sm" 
                          className="h-6 px-2 text-xs text-destructive"
                          onClick={(e) => {
                            e.stopPropagation()
                            deleteTemplate(template.id)
                          }}
                        >
                          <Trash2 className="w-3 h-3 mr-1" />
                          删除
                        </Button>
                      </div>
                    )}
                  </CardContent>
                </Card>
              ))}
            </div>
          </ScrollArea>
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowTemplateDialog(false)}>关闭</Button>
            <Button onClick={() => {
              setShowTemplateDialog(false)
              openTemplateEdit()
            }}>
              <Plus className="w-4 h-4 mr-1" />
              添加模板
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* 模板编辑对话框 */}
      <Dialog open={showTemplateEditDialog} onOpenChange={setShowTemplateEditDialog}>
        <DialogContent className="max-w-md w-[95vw] md:w-full">
          <DialogHeader>
            <DialogTitle>{editingTemplate ? '编辑模板' : '添加模板'}</DialogTitle>
          </DialogHeader>
          <div className="space-y-4 py-4">
            <div className="space-y-2">
              <Label>模板名称</Label>
              <Input
                value={templateForm.name || ''}
                onChange={(e) => setTemplateForm(prev => ({ ...prev, name: e.target.value }))}
                placeholder="如：抖音点赞"
              />
            </div>
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
              <div className="space-y-2">
                <Label>平台</Label>
                <select
                  className="w-full h-9 rounded-md border border-input bg-background px-3 py-1 text-sm"
                  value={templateForm.platform || PLATFORMS.DOUYIN}
                  onChange={(e) => setTemplateForm(prev => ({ ...prev, platform: e.target.value }))}
                >
                  <option value={PLATFORMS.DOUYIN}>{PLATFORM_NAMES[PLATFORMS.DOUYIN]}</option>
                  <option value={PLATFORMS.XIAOHONGSHU}>{PLATFORM_NAMES[PLATFORMS.XIAOHONGSHU]}</option>
                  <option value={PLATFORMS.KUAISHOU}>{PLATFORM_NAMES[PLATFORMS.KUAISHOU]}</option>
                  <option value={PLATFORMS.SHIPINHAO}>{PLATFORM_NAMES[PLATFORMS.SHIPINHAO]}</option>
                </select>
              </div>
              <div className="space-y-2">
                <Label>操作类型</Label>
                <select
                  className="w-full h-9 rounded-md border border-input bg-background px-3 py-1 text-sm"
                  value={templateForm.action || TASK_ACTIONS.SHORT_VIDEO_RESEARCH}
                  onChange={(e) => setTemplateForm(prev => ({ ...prev, action: e.target.value }))}
                >
                  <option value={TASK_ACTIONS.SHORT_VIDEO_RESEARCH}>短视频内容体验调研</option>
                </select>
              </div>
            </div>
            <div className="grid grid-cols-3 gap-4">
              <div className="space-y-2">
                <Label>奖励积分</Label>
                <Input
                  type="number"
                  value={templateForm.reward || ''}
                  onChange={(e) => setTemplateForm(prev => ({ ...prev, reward: parseInt(e.target.value) || 0 }))}
                  placeholder="30"
                />
              </div>
              <div className="space-y-2">
                <Label>需要人数</Label>
                <Input
                  type="number"
                  value={templateForm.remain || ''}
                  onChange={(e) => setTemplateForm(prev => ({ ...prev, remain: parseInt(e.target.value) || 10 }))}
                  placeholder="10"
                />
              </div>
              <div className="space-y-2">
                <Label>任务时长(分钟)</Label>
                <Input
                  type="number"
                  value={templateForm.timeLimitMinutes || ''}
                  onChange={(e) => setTemplateForm(prev => ({ ...prev, timeLimitMinutes: parseInt(e.target.value) || 15 }))}
                  placeholder="15"
                />
              </div>
            </div>
            <div className="space-y-2">
              <Label>描述</Label>
              <Textarea
                value={templateForm.desc || ''}
                onChange={(e) => setTemplateForm(prev => ({ ...prev, desc: e.target.value }))}
                placeholder="任务描述说明"
                className="min-h-[60px]"
              />
            </div>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setShowTemplateEditDialog(false)}>取消</Button>
            <Button onClick={saveTemplate}>保存</Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* 删除会话确认对话框 */}
      <AlertDialog open={!!deleteConversationId} onOpenChange={() => setDeleteConversationId(null)}>
        <AlertDialogContent>
          <AlertDialogHeader>
            <AlertDialogTitle>删除会话</AlertDialogTitle>
            <AlertDialogDescription>
              确定要删除这个会话吗？此操作无法撤销。
            </AlertDialogDescription>
          </AlertDialogHeader>
          <AlertDialogFooter>
            <AlertDialogCancel>取消</AlertDialogCancel>
            <AlertDialogAction 
              className="bg-destructive text-destructive-foreground"
              onClick={() => deleteConversationId && deleteConversation(deleteConversationId)}
            >
              删除
            </AlertDialogAction>
          </AlertDialogFooter>
        </AlertDialogContent>
      </AlertDialog>
    </div>
  )
}
